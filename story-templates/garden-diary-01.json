{
  "id": "garden-diary-01",
  "version": 1,
  "name": "Garden Diary",
  "tier": "smart_lite",
  "libraryTheme": "white_weddings",
  "storyArc": {
    "sequence": [
      "morning",
      "portraits",
      "details",
      "promenade",
      "vows",
      "golden_hour",
      "closing"
    ]
  },
  "transitionGrammar": {
    "vocabulary": [
      "fade_slow",
      "dissolve",
      "crossfade",
      "none"
    ],
    "specialRoles": [
      "memory",
      "peak"
    ],
    "limits": {
      "memory": 2,
      "peak": 1
    }
  },
  "source": {
    "origin": "original",
    "notes": "A botanical daybook inspired by White Weddings' warm ivory pages, but organized around garden light from morning preparation to golden hour."
  },
  "fit": {
    "bestFor": [
      "garden",
      "outdoor",
      "botanical",
      "daylight",
      "white_wedding"
    ],
    "minPhotos": 24,
    "idealPhotos": 58
  },
  "musicProfile": {
    "moods": [
      "acoustic",
      "gentle",
      "romantic"
    ],
    "energy": "low_to_medium"
  },
  "pacingVariants": [
    {
      "id": "dew",
      "maxEnergy": 0.35,
      "durationMultiplier": 1.16
    },
    {
      "id": "garden",
      "maxEnergy": 0.68,
      "durationMultiplier": 1
    },
    {
      "id": "sunlight",
      "maxEnergy": 1,
      "durationMultiplier": 0.87
    }
  ],
  "briefFields": {
    "required": [
      "bride",
      "groom"
    ],
    "optional": [
      "date",
      "location",
      "thankYouLine"
    ]
  },
  "defaults": {
    "project": {
      "width": 1920,
      "height": 1080,
      "fps": 30,
      "quality": "share"
    },
    "color": {
      "temperature": 5700,
      "saturation": 1.06,
      "contrast": 1.02,
      "glow": 0.12,
      "grain": 1
    },
    "audio": {
      "fade_in": 2,
      "fade_out": 3.5,
      "crossfade": 0
    },
    "overlays": [],
    "fonts": {
      "title": "fonts/GreatVibes-Regular.ttf",
      "heading": "fonts/PlayfairDisplay.ttf",
      "body": "fonts/BeVietnamPro-Regular.ttf"
    },
    "palette": {
      "cream": "#FBF6ED",
      "ink": "#2D2D33",
      "brown": "#71805D",
      "white": "#FFFDFC"
    }
  },
  "timelineRules": {
    "durationStrategy": {
      "baseSceneSec": 5.8,
      "calmSceneSec": 7.4,
      "buildSceneSec": 4.6,
      "montageSec": 10,
      "closingSec": 8.5
    },
    "transitionStrategy": {
      "default": {
        "type": "dissolve",
        "duration": 0.8
      },
      "calm": {
        "type": "fade_slow",
        "duration": 1.1
      },
      "memory": {
        "type": "dissolve",
        "duration": 0.9
      },
      "peak": {
        "type": "crossfade",
        "duration": 0.55
      },
      "final": {
        "type": "none",
        "duration": 0
      }
    },
    "photoSelection": {
      "reusePolicy": "avoid_until_exhausted",
      "heroPriority": [
        "qualityNorm",
        "heroScore",
        "emotionScore"
      ],
      "fallbackPriority": [
        "qualityNorm",
        "sharpness",
        "meanLuma"
      ],
      "darkPhotoMaxMeanLuma": 75
    }
  },
  "scenes": [
    {
      "id": "s01_morning",
      "effect": "layer_scene",
      "layout": "save_date_card",
      "durationRole": "calm",
      "transitionRole": "calm",
      "photoSlots": [
        {
          "slot": "bg",
          "orient": "landscape",
          "quality": "best"
        },
        {
          "slot": "p1",
          "orient": "portrait",
          "quality": "good"
        },
        {
          "slot": "p2",
          "orient": "portrait",
          "quality": "good"
        },
        {
          "slot": "p3",
          "orient": "portrait",
          "quality": "good"
        }
      ],
      "text": {
        "heading": "GARDEN DIARY",
        "date": "{{date}}"
      }
    },
    {
      "id": "s02_portraits",
      "effect": "layer_scene",
      "layout": "arch_trio",
      "durationRole": "normal",
      "transitionRole": "memory",
      "photoSlots": [
        {
          "slot": "left",
          "orient": "portrait",
          "quality": "good"
        },
        {
          "slot": "centre",
          "orient": "portrait",
          "quality": "best"
        },
        {
          "slot": "right",
          "orient": "portrait",
          "quality": "good"
        }
      ]
    },
    {
      "id": "s03_details",
      "effect": "still",
      "renderer": "remotion",
      "template": "confetti_bloom",
      "params": {
        "background": "#FBF6ED"
      },
      "signature": true,
      "durationRole": "normal",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "portrait",
          "quality": "best"
        }
      ],
      "captionPattern": "LITTLE BOTANICAL MOMENTS"
    },
    {
      "id": "s04_walk",
      "effect": "layer_scene",
      "layout": "journey_duo",
      "durationRole": "calm",
      "transitionRole": "memory",
      "photoSlots": [
        {
          "slot": "wide",
          "orient": "landscape",
          "quality": "best"
        },
        {
          "slot": "accent",
          "orient": "portrait",
          "quality": "good"
        }
      ],
      "text": {
        "heading": "A walk to remember",
        "caption": "Trong khu vườn, giữa những người mình thương."
      },
      "muteFallback": {
        "layout": "photo_duo",
        "photoSlots": [
          {
            "slot": "left",
            "orient": "portrait",
            "quality": "good"
          },
          {
            "slot": "right",
            "orient": "portrait",
            "quality": "good"
          }
        ]
      },
      "repeatable": {
        "maxRepeats": 3,
        "variants": [
          {
            "text": {
              "heading": "Bên nhau",
              "caption": "Chuyện chúng mình, viết tiếp mỗi ngày."
            }
          },
          {
            "text": {
              "heading": "Thương nhau",
              "caption": "Hạnh phúc là được nắm tay nhau thật lâu."
            }
          }
        ]
      }
    },
    {
      "id": "s05_vows",
      "effect": "mask_reveal",
      "mask": "assets/masks/gold_dust_reveal.mp4",
      "durationRole": "calm",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "landscape",
          "quality": "best"
        }
      ],
      "params": {
        "background": "#4A4139"
      }
    },
    {
      "id": "s55_diary_pages",
      "effect": "layer_scene",
      "layout": "paper_collage",
      "durationRole": "normal",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "back",
          "orient": "any",
          "quality": "good"
        },
        {
          "slot": "centre",
          "orient": "portrait",
          "quality": "best"
        },
        {
          "slot": "front",
          "orient": "any",
          "quality": "good"
        }
      ],
      "text": {
        "heading": "Trang nhật ký của mình"
      },
      "repeatable": {
        "maxRepeats": 3,
        "variants": [
          {
            "text": {
              "heading": "Những trang viết tay"
            }
          },
          {
            "text": {}
          }
        ]
      }
    },
    {
      "id": "s06_golden",
      "effect": "memory_wall",
      "durationRole": "montage",
      "transitionRole": "peak",
      "photoSlots": [
        {
          "slot": "memories",
          "count": 8,
          "orient": "any",
          "quality": "good",
          "preferVariety": true
        }
      ],
      "captionPattern": "GOLDEN HOUR · {{bride}} & {{groom}}",
      "params": {
        "background": "#4A4139"
      }
    },
    {
      "id": "s07_close",
      "effect": "layer_scene",
      "layout": "closing_names",
      "durationRole": "closing",
      "transitionRole": "final",
      "photoSlots": [],
      "text": {
        "names": "{{bride}} & {{groom}}",
        "date": "{{location}} · {{date}}"
      }
    }
  ]
}
