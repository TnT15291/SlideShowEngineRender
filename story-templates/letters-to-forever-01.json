{
  "id": "letters-to-forever-01",
  "version": 1,
  "name": "Letters to Forever",
  "tier": "smart_lite",
  "libraryTheme": "white_weddings",
  "storyArc": {
    "sequence": [
      "dear_you",
      "first_letter",
      "chapters",
      "proposal",
      "vows",
      "postscript",
      "closing"
    ]
  },
  "transitionGrammar": {
    "vocabulary": [
      "fade_slow",
      "dissolve",
      "crossfade",
      "none"
    ],
    "specialRoles": [
      "memory",
      "peak"
    ],
    "limits": {
      "memory": 2,
      "peak": 1
    }
  },
  "source": {
    "origin": "original",
    "notes": "An intimate epistolary template built like exchanged letters, with paper collage pages and handwritten-feeling English accents over Vietnamese-safe body copy."
  },
  "fit": {
    "bestFor": [
      "intimate",
      "vows",
      "letters",
      "editorial",
      "small_wedding"
    ],
    "minPhotos": 20,
    "idealPhotos": 48
  },
  "musicProfile": {
    "moods": [
      "piano",
      "intimate",
      "gentle"
    ],
    "energy": "low"
  },
  "pacingVariants": [
    {
      "id": "whisper",
      "maxEnergy": 0.35,
      "durationMultiplier": 1.18
    },
    {
      "id": "reading",
      "maxEnergy": 0.65,
      "durationMultiplier": 1
    },
    {
      "id": "montage",
      "maxEnergy": 1,
      "durationMultiplier": 0.88
    }
  ],
  "briefFields": {
    "required": [
      "bride",
      "groom"
    ],
    "optional": [
      "date",
      "location",
      "thankYouLine"
    ]
  },
  "defaults": {
    "project": {
      "width": 1920,
      "height": 1080,
      "fps": 30,
      "quality": "share"
    },
    "color": {
      "temperature": 5500,
      "saturation": 0.98,
      "contrast": 1.02,
      "glow": 0.08,
      "grain": 2
    },
    "audio": {
      "fade_in": 2.2,
      "fade_out": 4,
      "crossfade": 0
    },
    "overlays": [],
    "fonts": {
      "title": "fonts/GreatVibes-Regular.ttf",
      "heading": "fonts/PlayfairDisplay.ttf",
      "body": "fonts/BeVietnamPro-Regular.ttf"
    },
    "palette": {
      "cream": "#FAF3E8",
      "ink": "#34302D",
      "brown": "#856E58",
      "white": "#FFFDFC"
    }
  },
  "timelineRules": {
    "durationStrategy": {
      "baseSceneSec": 6,
      "calmSceneSec": 8,
      "buildSceneSec": 5,
      "montageSec": 10,
      "closingSec": 9
    },
    "transitionStrategy": {
      "default": {
        "type": "dissolve",
        "duration": 0.85
      },
      "calm": {
        "type": "fade_slow",
        "duration": 1.15
      },
      "memory": {
        "type": "dissolve",
        "duration": 1
      },
      "peak": {
        "type": "crossfade",
        "duration": 0.6
      },
      "final": {
        "type": "none",
        "duration": 0
      }
    },
    "photoSelection": {
      "reusePolicy": "avoid_until_exhausted",
      "heroPriority": [
        "qualityNorm",
        "heroScore",
        "emotionScore"
      ],
      "fallbackPriority": [
        "qualityNorm",
        "sharpness",
        "meanLuma"
      ],
      "darkPhotoMaxMeanLuma": 72
    }
  },
  "scenes": [
    {
      "id": "s01_dear",
      "effect": "layer_scene",
      "layout": "welcome_title_page",
      "durationRole": "calm",
      "transitionRole": "calm",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "portrait",
          "quality": "best"
        }
      ],
      "text": {
        "eyebrow": "DEAR YOU,",
        "names": "{{bride}} & {{groom}}",
        "date": "Một lá thư gửi đến ngày mai"
      }
    },
    {
      "id": "s02_first",
      "effect": "layer_scene",
      "layout": "paper_collage",
      "durationRole": "normal",
      "transitionRole": "memory",
      "photoSlots": [
        {
          "slot": "back",
          "orient": "any",
          "quality": "good"
        },
        {
          "slot": "centre",
          "orient": "portrait",
          "quality": "best"
        },
        {
          "slot": "front",
          "orient": "any",
          "quality": "good"
        }
      ],
      "text": {
        "heading": "Lá thư đầu tiên"
      },
      "repeatable": {
        "maxRepeats": 3,
        "variants": [
          {
            "text": {
              "heading": "Bên nhau"
            }
          },
          {
            "text": {
              "heading": "Ngày chung đôi"
            }
          }
        ]
      }
    },
    {
      "id": "s03_pages",
      "effect": "panel_flip",
      "signature": true,
      "durationRole": "normal",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "portrait",
          "quality": "best"
        }
      ],
      "captionPattern": "CHAPTERS OF US",
      "repeatable": {
        "maxRepeats": 3,
        "variants": [
          {
            "captionPattern": "Cảm ơn vì đã cùng nhau đến tận đây."
          },
          {
            "captionPattern": ""
          }
        ]
      }
    },
    {
      "id": "s04_promise",
      "effect": "layer_scene",
      "layout": "two_photo_story",
      "durationRole": "calm",
      "transitionRole": "memory",
      "photoSlots": [
        {
          "slot": "portrait",
          "orient": "portrait",
          "quality": "best"
        },
        {
          "slot": "wide",
          "orient": "landscape",
          "quality": "good"
        }
      ],
      "text": {
        "body": "Mình đã viết nên rất nhiều ngày bình thường, để hôm nay cùng ký tên vào một lời hứa."
      }
    },
    {
      "id": "s05_vows",
      "effect": "mask_reveal",
      "mask": "assets/masks/gold_dust_reveal.mp4",
      "durationRole": "calm",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "landscape",
          "quality": "best"
        }
      ],
      "params": {
        "background": "#4A4139"
      }
    },
    {
      "id": "s06_postscript",
      "effect": "layer_scene",
      "layout": "polaroid_scatter",
      "durationRole": "montage",
      "transitionRole": "peak",
      "photoSlots": [
        {
          "slot": "p1",
          "orient": "any",
          "quality": "good"
        },
        {
          "slot": "p2",
          "orient": "any",
          "quality": "best"
        },
        {
          "slot": "p3",
          "orient": "any",
          "quality": "good"
        }
      ],
      "text": {
        "heading": "P.S. · Và câu chuyện vẫn tiếp tục"
      }
    },
    {
      "id": "s71_signature",
      "effect": "still",
      "renderer": "remotion",
      "template": "panel_reveal",
      "signature": true,
      "durationRole": "normal",
      "transitionRole": "default",
      "photoSlots": [
        {
          "slot": "hero",
          "orient": "any",
          "quality": "best"
        }
      ]
    },
    {
      "id": "s07_close",
      "effect": "layer_scene",
      "layout": "closing_names",
      "durationRole": "closing",
      "transitionRole": "final",
      "photoSlots": [],
      "text": {
        "names": "Yours, always",
        "date": "{{bride}} & {{groom}} · {{date}}"
      }
    }
  ]
}
