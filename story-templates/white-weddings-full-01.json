{
  "id": "white-weddings-full-01",
  "version": 1,
  "name": "White Weddings Full Collection",
  "tier": "smart_lite",
  "libraryTheme": "white_weddings",
  "storyArc": {
    "sequence": [
      "save_the_date",
      "establish",
      "couple",
      "details",
      "story",
      "memories",
      "celebration",
      "closing"
    ]
  },
  "transitionGrammar": {
    "vocabulary": [
      "dissolve",
      "crossfade",
      "fade_slow",
      "none"
    ],
    "specialRoles": [
      "memory",
      "peak"
    ],
    "limits": {
      "memory": 3,
      "peak": 1
    }
  },
  "source": {
    "origin": "reference_adaptation",
    "notes": "Reverse-engineered from the local White Weddings Theme reference video's full 390s / 39-page venue-loop (templates/Weddings/White Weddings Theme). Broadens white-weddings-editorial-01 with the loop's extra layout vocabulary — masonry grid wall, tinted spread, save-the-date card, polaroid feature, arch/gazebo breathers — added to layouts/library.json. Almost entirely layer_scene (flat Canva-style pages, matching what the reference actually does), plus one mask_reveal signature beat to satisfy the engine's advanced-effect requirement."
  },
  "fit": {
    "bestFor": [
      "pre_wedding",
      "save_the_date",
      "garden",
      "editorial",
      "minimal",
      "white_wedding"
    ],
    "minPhotos": 20,
    "idealPhotos": 55
  },
  "musicProfile": {
    "moods": [
      "romantic",
      "elegant",
      "gentle",
      "acoustic"
    ],
    "energy": "low_to_medium"
  },
  "pacingVariants": [
    {
      "id": "vow",
      "maxEnergy": 0.38,
      "durationMultiplier": 1.14
    },
    {
      "id": "editorial",
      "maxEnergy": 0.68,
      "durationMultiplier": 1
    },
    {
      "id": "celebration",
      "maxEnergy": 1,
      "durationMultiplier": 0.88
    }
  ],
  "briefFields": {
    "required": [
      "bride",
      "groom"
    ],
    "optional": [
      "date",
      "location",
      "thankYouLine"
    ]
  },
  "defaults": {
    "project": {
      "width": 1920,
      "height": 1080,
      "fps": 30,
      "quality": "share"
    },
    "color": {
      "temperature": 5600,
      "saturation": 1.02,
      "contrast": 1.03,
      "glow": 0.08,
      "grain": 1
    },
    "audio": {
      "fade_in": 1.8,
      "fade_out": 3.5,
      "crossfade": 0
    },
    "overlays": [],
    "fonts": {
      "title": "fonts/GreatVibes-Regular.ttf",
      "heading": "fonts/PlayfairDisplay.ttf",
      "body": "fonts/BeVietnamPro-Regular.ttf"
    },
    "palette": {
      "cream": "#FBF6ED",
      "ink": "#2D2D33",
      "brown": "#634C31",
      "white": "#FFFDFC"
    }
  },
  "timelineRules": {
    "durationStrategy": {
      "baseSceneSec": 5.8,
      "calmSceneSec": 7.4,
      "buildSceneSec": 4.8,
      "montageSec": 10.5,
      "closingSec": 8.5
    },
    "transitionStrategy": {
      "default": {
        "type": "dissolve",
        "duration": 0.8
      },
      "calm": {
        "type": "fade_slow",
        "duration": 1.1
      },
      "memory": {
        "type": "dissolve",
        "duration": 0.9
      },
      "peak": {
        "type": "crossfade",
        "duration": 0.6
      },
      "final": {
        "type": "none",
        "duration": 0
      }
    },
    "photoSelection": {
      "reusePolicy": "avoid_until_exhausted",
      "heroPriority": [
        "qualityNorm",
        "heroScore",
        "emotionScore"
      ],
      "fallbackPriority": [
        "qualityNorm",
        "sharpness",
        "meanLuma"
      ],
      "darkPhotoMaxMeanLuma": 72
    }
  },
