{
  "id": "korean-soft-romance-01",
  "version": 1,
  "name": "Korean Soft Romance",
  "tier": "smart_lite",
  "source": {
    "origin": "original",
    "notes": "Built as an original reusable wedding story template. It is not copied from a marketplace timeline."
  },
  "fit": {
    "bestFor": [
      "prewedding",
      "wedding_day",
      "couple_journey",
      "soft_romance",
      "family_warmth"
    ],
    "minPhotos": 35,
    "idealPhotos": 70,
    "requiredPhotoMix": {
      "couple": 12,
      "portrait": 10,
      "family_or_group": 6,
      "detail_or_scenery": 4
    },
    "avoidIf": [
      "mostly_party_photos",
      "mostly_dark_indoor_photos",
      "fewer_than_25_photos"
    ]
  },
  "musicProfile": {
    "moods": ["romantic", "soft", "cinematic", "warm"],
    "energy": "low_to_medium",
    "bpmRange": [68, 105],
    "idealDurationSec": [150, 240],
    "instruments": ["piano", "strings", "acoustic_guitar", "soft_pad"],
    "avoid": ["heavy_drums", "aggressive_edm", "hard_rock"]
  },
  "briefFields": {
    "required": ["bride", "groom"],
    "optional": ["date", "location", "meetingPlace", "yearsTogether", "thankYouLine"]
  },
  "defaults": {
    "project": {
      "width": 1920,
      "height": 1080,
      "fps": 30,
      "quality": "share"
    },
    "color": {
      "temperature": 5800,
      "saturation": 1.04,
      "contrast": 1.02,
      "glow": 0.18,
      "vignette": true,
      "grain": 3
    },
    "audio": {
      "fade_in": 1.5,
      "fade_out": 3,
      "crossfade": 0
    },
    "overlays": [
      {
        "variant": "soft",
        "position": "fullscreen",
        "opacity": 0.35,
        "blend": "screen",
        "start": 0
      }
    ],
    "fonts": {
      "title": "fonts/GreatVibes-Regular.ttf",
      "heading": "fonts/PlayfairDisplay.ttf",
      "body": "fonts/BeVietnamPro-Regular.ttf"
    },
    "palette": {
      "cream": "#FBF6ED",
      "ink": "#2D2D33",
      "brown": "#634C31",
      "white": "#FFFFFF"
    }
  },
  "storyArc": {
    "logline": "A gentle love story told through quiet beginnings, shared memories, family warmth, and the promise of a new home.",
    "segments": [
      "opening",
      "first_chapter",
      "everyday_love",
      "journey_together",
      "family_blessing",
      "wedding_day",
      "ending"
    ]
  },
  "timelineRules": {
    "durationStrategy": {
      "baseSceneSec": 6,
      "calmSceneSec": 7.2,
      "buildSceneSec": 4.8,
      "montageSec": 12,
      "closingSec": 8
    },
    "transitionStrategy": {
      "default": {
        "type": "crossfade",
        "duration": 0.8
      },
      "calm": {
        "type": "fade_slow",
        "duration": 1
      },
      "memory": {
        "type": "dissolve",
        "duration": 0.75
      },
      "peak": {
        "type": "smooth_left",
        "duration": 0.55
      },
      "final": {
        "type": "none",
        "duration": 0
      }
    },
    "photoSelection": {
      "reusePolicy": "avoid_until_exhausted",
      "heroPriority": ["qualityNorm", "heroScore", "emotionScore", "skinFrac"],
      "fallbackPriority": ["qualityNorm", "sharpness", "meanLuma"],
      "darkPhotoMaxMeanLuma": 75
    }
  },
  "scenes": [
    {
      "id": "s01_opening_title",
      "segment": "opening",
      "purpose": "Introduce the couple with an elegant, slow emotional start.",
      "effect": "layer_scene",
      "durationRole": "calm",
      "transitionRole": "calm",
      "captionPattern": "{{bride}} & {{groom}}",
      "subtitlePattern": "{{date}}",
      "photoSlots": [
        {
          "slot": "background",
          "count": 1,
          "orient": "landscape",
          "tags": ["couple", "scenery", "venue"],
          "quality": "best",
          "fit": "cover",
          "motion": "zoom_in"
        },
        {
          "slot": "portrait_left",
          "count": 1,
          "orient": "portrait",
          "tags": ["bride", "couple", "portrait"],
          "quality": "high",
          "fit": "cover",
          "frame": "soft_card"
        },
        {
          "slot": "portrait_right",
          "count": 1,
          "orient": "portrait",
          "tags": ["groom", "couple", "portrait"],
          "quality": "high",
          "fit": "cover",
          "frame": "soft_card"
        }
      ],
      "layoutHint": "full_bleed_background_with_two_portrait_cards",
      "textTone": "minimal"
    },
    {
      "id": "s02_first_chapter",
      "segment": "first_chapter",
      "purpose": "Give the story a beginning without needing too many personal details.",
      "effect": "layer_scene",
      "durationRole": "calm",
      "transitionRole": "default",
      "captionPattern": "Từ một lần gặp gỡ, mình bắt đầu một hành trình rất riêng.",
      "photoSlots": [
        {
          "slot": "hero",
          "count": 1,
          "orient": "portrait",
          "tags": ["couple", "portrait", "candid"],
          "quality": "best",
          "motion": "zoom_in"
        },
        {
          "slot": "supporting",
          "count": 2,
          "orient": "landscape",
          "tags": ["couple", "scenery", "candid"],
          "quality": "good"
        }
      ],
      "layoutHint": "large_portrait_with_two_supporting_landscapes",
      "textTone": "gentle_narration"
    },
    {
      "id": "s03_memory_wall",
      "segment": "everyday_love",
      "purpose": "Show many ordinary memories quickly while keeping the tone soft.",
      "effect": "memory_wall",
      "durationRole": "normal",
      "transitionRole": "memory",
      "captionPattern": "Những ngày bình thường trở thành kỷ niệm vì có nhau.",
      "photoSlots": [
        {
          "slot": "memories",
          "count": 5,
          "orient": "any",
          "tags": ["couple", "candid", "friends", "scenery"],
          "quality": "good",
          "allowMixedOrientation": true
        }
      ],
      "textTone": "warm"
    },
    {
      "id": "s04_together_journey",
      "segment": "journey_together",
      "purpose": "Represent travel, dates, and time spent together.",
      "effect": "collage_grid",
      "durationRole": "build",
      "transitionRole": "peak",
      "captionPattern": "Mình đi qua nhiều nơi, nhưng điều đáng nhớ nhất vẫn là đi cùng nhau.",
      "photoSlots": [
        {
          "slot": "grid",
          "count": 6,
          "orient": "any",
          "tags": ["couple", "scenery", "candid", "friends"],
          "quality": "good",
          "preferVariety": true
        }
      ],
      "textTone": "light"
    },
    {
      "id": "s05_soft_portraits",
      "segment": "journey_together",
      "purpose": "Slow down with two beautiful portrait moments.",
      "effect": "layer_scene",
      "durationRole": "calm",
      "transitionRole": "default",
      "captionPattern": "Có những khoảnh khắc không cần nói nhiều, chỉ cần được giữ lại.",
      "photoSlots": [
        {
          "slot": "left",
          "count": 1,
          "orient": "portrait",
          "tags": ["bride", "portrait", "couple"],
          "quality": "best",
          "frame": "soft_card",
          "motion": "zoom_in"
        },
        {
          "slot": "right",
          "count": 1,
          "orient": "portrait",
          "tags": ["groom", "portrait", "couple"],
          "quality": "best",
          "frame": "soft_card",
          "motion": "zoom_in"
        }
      ],
      "layoutHint": "two_portrait_cards_on_cream_background",
      "textTone": "poetic"
    },
    {
      "id": "s06_family_blessing",
      "segment": "family_blessing",
      "purpose": "Bring parents, family, and friends into the emotional arc.",
      "effect": "layer_scene",
      "durationRole": "calm",
      "transitionRole": "memory",
      "captionPattern": "Tình yêu hôm nay có thêm lời chúc phúc của gia đình và những người thương.",
      "photoSlots": [
        {
          "slot": "family_hero",
          "count": 1,
          "orient": "landscape",
          "tags": ["family", "group", "ceremony"],
          "quality": "best",
          "motion": "pan_left"
        },
        {
          "slot": "family_support",
          "count": 2,
          "orient": "any",
          "tags": ["family", "friends", "group"],
          "quality": "good"
        }
      ],
      "layoutHint": "hero_family_photo_with_supporting_cards",
      "textTone": "thankful"
    },
    {
      "id": "s07_wedding_day_montage",
      "segment": "wedding_day",
      "purpose": "Use the most energetic section to show ceremony and celebration.",
      "effect": "film_roll_left",
      "durationRole": "montage",
      "transitionRole": "peak",
      "captionPattern": "Và hôm nay, câu chuyện ấy bước sang một chương mới.",
      "photoSlots": [
        {
          "slot": "film_roll",
          "count": 8,
          "orient": "any",
          "tags": ["ceremony", "vows", "rings", "kiss", "reception", "party", "group"],
          "quality": "good",
          "preferEmotion": true
        }
      ],
      "textTone": "celebratory"
    },
    {
      "id": "s08_hero_promise",
      "segment": "wedding_day",
      "purpose": "Return to one strong couple image after the montage.",
      "effect": "dark_feather",
      "durationRole": "normal",
      "transitionRole": "calm",
      "captionPattern": "Từ hôm nay, mình gọi nhau là nhà.",
      "photoSlots": [
        {
          "slot": "hero",
          "count": 1,
          "orient": "landscape",
          "tags": ["couple", "ceremony", "portrait", "kiss"],
          "quality": "best",
          "preferHeroScore": true
        }
      ],
      "textTone": "emotional"
    },
    {
      "id": "s09_ending",
      "segment": "ending",
      "purpose": "Close with names, date, and a quiet thank-you feeling.",
      "effect": "layer_scene",
      "durationRole": "closing",
      "transitionRole": "final",
      "captionPattern": "{{bride}} & {{groom}}",
      "subtitlePattern": "{{location}} · {{date}}",
      "fallbackSubtitlePattern": "Thank you for being part of our story",
      "photoSlots": [
        {
          "slot": "background",
          "count": 1,
          "orient": "landscape",
          "tags": ["couple", "scenery", "venue"],
          "quality": "best",
          "fit": "cover",
          "motion": "zoom_out"
        }
      ],
      "layoutHint": "full_bleed_with_centered_names",
      "textTone": "closing"
    }
  ],
  "layoutPresets": {
    "soft_card": {
      "radius": 26,
      "border": 12,
      "borderColor": "#FFFFFF",
      "shadow": true
    }
  },
  "renderNotes": [
    "This template is a blueprint, not a directly renderable timeline.",
    "An apply-template script should resolve photoSlots to real image paths, replace {{tokens}}, assign exact durations from music energy, then emit timeline JSON.",
    "If semantic photo tags are unavailable, use technical analysis only and map slots by orientation plus quality."
  ]
}
