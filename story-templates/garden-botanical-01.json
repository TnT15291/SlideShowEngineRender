    { "id": "s03_flowers", "effect": "video_background", "background": "assets/backgrounds/mixkit_wedding_flower_arrangement_calla_lilies_1080.mp4", "durationRole": "normal", "transitionRole": "memory", "captionPattern": "Một khoảng lặng dành cho những điều dịu dàng." , "photoSlots": [] },
    { "id": "s04_family", "effect": "layer_scene", "layout": "three_photo_row", "durationRole": "normal", "transitionRole": "default", "photoSlots": [{ "slot": "left", "orient": "any", "quality": "good" }, { "slot": "centre", "orient": "any", "quality": "best" }, { "slot": "right", "orient": "any", "quality": "good" }], "text": { "heading": "Người thương", "caption": "Ngày vui trọn vẹn khi có gia đình và bạn bè ở bên." } },
    { "id": "s05_breath", "effect": "mask_reveal", "mask": "assets/masks/heart_wand.mp4", "signature": true, "durationRole": "calm", "transitionRole": "default", "photoSlots": [{ "slot": "hero", "orient": "landscape", "quality": "best" }] },
