    { "id": "s07_closing", "effect": "layer_scene", "layout": "closing_names", "durationRole": "closing", "transitionRole": "final", "frameOverlay": "assets/frames/custom-wedding-frames-20/wedding_frame_botanical_03.png", "photoSlots": [], "text": { "names": "{{bride}} & {{groom}}", "date": "{{location}} · {{date}}" } }
