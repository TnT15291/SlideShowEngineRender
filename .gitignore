node_modules/
temp/
tmp/
output/
logs/
*.log

# Secrets. Nothing here loads a .env — the API keys come from the environment
# (OPENAI_API_KEY, DEEPSEEK_API_KEY), set once at Windows User scope like
# FFMPEG_PATH already is. A .env would therefore be BOTH inert and committable,
# which is the worst pair of properties a secrets file can have. Ignored so that
# writing one can only waste your time, never leak a key.
.env
.env.*
!.env.example

# Local Claude Code state (settings.json IS tracked and must never hold a key;
# these are per-machine).
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Canva "Weddings" theme reference material: 316 SVGs with embedded base64 art,
# 3.5 GB. Reverse-engineering input, re-downloadable, never imported by the engine.
templates/

# Stock media (mixkit backgrounds, theme audio) — licensed downloads, not sources.
# The licence records are text and DO belong in the repo.
assets/*
!assets/licenses/

# LUTs and reveal masks are NOT stock: scripts/generateLuts.mjs and generateMasks.mjs
# emit them, and a timeline referencing `mask_reveal` or a LUT fails without them.
# Same nature as overlays/ (procedural, tracked) and small enough to carry: 4 MB.
!assets/luts/
!assets/masks/

# The couple's photographs. Irreplaceable, but binary and private: back these up
# somewhere real, not in git. The pipeline reads them from input/ on disk.
input/

# Licensed audio.
music/

# Every generated video job owns private inputs, analysis, timeline, logs and output.
projects/

# Regenerated by the pipeline on demand.
analysis/qa/frames/
analysis/photos.pruned.json

# `analyzePhotoContent --limit N` probe: a SAMPLE of the photo set, kept in its own
# file so it can never be mistaken for analysis/photo_content.json (which the
# pipeline reads as the complete set). Cheap to regenerate; a stale sample misleads.
analysis/photo_content.sample.json

# Node 4 runtime state: the open response window and the message actually sent to
# / received from the customer. Per-job, not source. (selected_story.json — the
# DECISION — is a real artifact and stays tracked.)
analysis/story_choice_window.json
analysis/choice_outbox.txt
analysis/choice_inbox.txt
