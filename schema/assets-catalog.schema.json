{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slideshow-render-engine/assets-catalog.schema.json",
  "title": "Asset Catalog",
  "description": "Local asset catalog generated by scripts/analyzeAssets.mjs. The full file keeps paths/license hints for code; the AI file keeps short labels/tags for AI Director prompts.",
  "type": "object",
  "required": ["generatedAt", "version", "counts", "fonts", "overlays", "backgrounds", "frames"],
  "additionalProperties": true,
  "properties": {
    "generatedAt": { "type": "string" },
    "version": { "type": "integer" },
    "purpose": { "type": "string" },
    "counts": {
      "type": "object",
      "required": ["fonts", "overlays", "backgrounds", "frames"],
      "properties": {
        "fonts": { "type": "integer", "minimum": 0 },
        "overlays": { "type": "integer", "minimum": 0 },
        "backgrounds": { "type": "integer", "minimum": 0 },
        "frames": { "type": "integer", "minimum": 0 }
      }
    },
    "fonts": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
    "overlays": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
    "backgrounds": { "type": "array", "items": { "$ref": "#/$defs/asset" } },
    "frames": { "type": "array", "items": { "$ref": "#/$defs/asset" } }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": ["id", "type", "label"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["font", "overlay", "video_background", "frame"] },
        "path": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "mood": { "type": "array", "items": { "type": "string" } },
        "bestFor": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "roles": { "type": "array", "items": { "type": "string" } },
        "variant": { "type": "string" }
      }
    }
  }
}
