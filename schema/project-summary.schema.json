{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "project_summary",
  "description": "Node 12 deliverable manifest. Records WHAT was shipped and HOW it was decided, including the provenance gates (stub vs real vision) so a summary never implies a judgement the pipeline did not actually make.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "generatedAt",
    "timeline",
    "tier",
    "provenance",
    "video",
    "content",
    "thumbnail",
    "preview",
    "deliverables"
  ],
  "properties": {
    "project": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "minLength": 1 },
    "timeline": { "type": "string", "minLength": 1 },

    "tier": {
      "description": "Which pipeline actually produced the timeline. Only the caller that generated it knows (renderWithRetry passes --tier); delivery must not guess, hence 'unknown'.",
      "type": "string",
      "enum": ["director", "lite", "unknown"]
    },

    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["photoContent", "artifacts"],
      "properties": {
        "photoContent": {
          "description": "Verbatim photo_content.generatedBy: 'stub' or 'vision:<host>/<model>'. 'stub' means every semantic score in this project is a placeholder.",
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "description": "Director-layer artifacts this render is attributed to. Empty unless --tier director, because their presence in analysis/ does not prove this timeline used them.",
          "type": "array",
          "items": { "type": "string" }
        },
        "note": { "type": "string" }
      }
    },

    "video": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "durationSec", "width", "height", "fps", "sizeBytes"],
      "properties": {
        "path": { "type": "string" },
        "durationSec": { "type": "number", "minimum": 0 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "minimum": 0 },
        "bitrateKbps": { "type": "number", "minimum": 0 },
        "sizeBytes": { "type": "integer", "minimum": 0 }
      }
    },

    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slides", "photosUsed", "uniquePhotos", "captions"],
      "properties": {
        "slides": { "type": "integer", "minimum": 0 },
        "photosUsed": { "type": "integer", "minimum": 0 },
        "uniquePhotos": { "type": "integer", "minimum": 0 },
        "captions": { "type": "integer", "minimum": 0 }
      }
    },

    "music": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "volume": { "type": "number", "minimum": 0 },
          "bpmEstimate": { "type": "number", "minimum": 0 },
          "durationSec": { "type": "number", "minimum": 0 }
        }
      }
    },

    "director": {
      "description": "Passthrough of director_notes.director_notes — already clamped to engine enums by the Phase B guardrail, so it is copied, not re-checked.",
      "type": "object"
    },

    "storyPlan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment"],
        "properties": {
          "segment": { "type": "string" },
          "emotion": { "type": "string" },
          "pacing": { "type": "string" },
          "emphasis": { "type": "string" }
        }
      }
    },

    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict"],
      "properties": {
        "verdict": { "type": "string", "enum": ["ok", "review", "unknown"] },
        "problems": { "type": "integer", "minimum": 0 },
        "source": { "type": "string" },
        "reason": { "type": "string" },
        "manualReview": { "type": "boolean" }
      }
    },

    "thumbnail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "timeSec", "chosenBy"],
      "properties": {
        "path": { "type": "string" },
        "timeSec": { "type": "number", "minimum": 0 },
        "chosenBy": {
          "description": "heroScore only when photo_content came from real vision; otherwise a deterministic fallback, named so the choice is auditable.",
          "type": "string",
          "enum": ["explicit", "heroScore", "longest-hero-slide", "midpoint"]
        },
        "reason": { "type": "string" },
        "sourcePhoto": { "type": "string" }
      }
    },

    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "width", "height", "sizeBytes"],
      "properties": {
        "path": { "type": "string" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "durationSec": { "type": "number", "minimum": 0 },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "watermark": { "type": "string" },
        "scaled": { "type": "boolean" }
      }
    },

    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "sizeBytes"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" },
          "sizeBytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
