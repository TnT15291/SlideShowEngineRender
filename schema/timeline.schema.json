{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slideshow-render-engine/timeline.schema.json",
  "title": "Wedding Render Engine — Timeline",
  "description": "Machine-checkable contract for the timeline JSON the engine renders. Mirrors src/validateTimeline.ts. The engine runs this structure check first, then semantic checks (unique slide ids, files exist, and the cross-field rules noted in $comment fields that pure JSON Schema cannot express).",
  "type": "object",
  "required": ["project", "output", "slides"],
  "additionalProperties": true,
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "width", "height", "fps"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "exclusiveMinimum": 0, "description": "Recommended 1920." },
        "height": { "type": "integer", "exclusiveMinimum": 0, "description": "Recommended 1080." },
        "fps": { "type": "integer", "exclusiveMinimum": 0, "description": "Recommended 30." },
        "quality": {
          "enum": ["draft", "share", "high", "master"],
          "description": "Render quality preset. Defaults to share during normalization."
        }
      }
    },
    "music": {
      "type": "array",
      "description": "Playlist; looped/crossfaded to cover the whole video. A single object is also accepted (normalization wraps it).",
      "items": {
        "type": "object",
        "required": ["path", "volume"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "volume": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "audio": {
      "type": "object",
      "description": "Master audio behaviour. Every field has a default so the block is optional.",
      "properties": {
        "fade_in": { "type": "number", "minimum": 0, "maximum": 30 },
        "fade_out": { "type": "number", "minimum": 0, "maximum": 30 },
        "crossfade": { "type": "number", "minimum": 0, "maximum": 30, "description": "Seconds of crossfade between playlist tracks." },
        "automation": {
          "type": "array",
          "description": "Master volume envelope; MUST be sorted by ascending 'at'.",
          "items": {
            "type": "object",
            "required": ["at", "volume"],
            "properties": {
              "at": { "type": "number", "minimum": 0 },
              "volume": { "type": "number", "minimum": 0, "maximum": 2 }
            }
          }
        },
        "voiceover": {
          "type": "object",
          "required": ["path", "start", "volume", "ducking"],
          "properties": {
            "path": { "type": "string", "minLength": 1 },
            "start": { "type": "number", "minimum": 0 },
            "volume": { "type": "number", "minimum": 0, "maximum": 2 },
            "ducking": { "type": "boolean", "description": "Sidechain-compress music under the voice." }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["path"],
      "properties": { "path": { "type": "string", "minLength": 1 } }
    },
    "color": { "$ref": "#/$defs/colorGrade" },
    "overlays": {
      "type": "array",
      "description": "Layered over the whole video in order: PNG frames/logos, black-bg bokeh/particle loops (blend 'screen'/'add'), or a bundled light leak via 'variant'.",
      "items": {
        "type": "object",
        "anyOf": [{ "required": ["path"] }, { "required": ["variant"] }],
        "properties": {
          "path": { "type": "string", "minLength": 1, "description": ".png/.jpg = image; .mp4/.mov/.webm = looping video. Omit when using 'variant'." },
          "variant": {
            "enum": ["warm", "soft", "sunset"],
            "description": "Bundled analog light-leak loop (overlays/light_leak_<variant>.mp4): warm = golden top-right corner leak, soft = near-white top-edge wash, sunset = orange+magenta left sweep. Alternative to 'path' (never both). Defaults blend to 'screen' and opacity to 0.6; recommended opacity 0.4-0.7."
          },
          "position": { "enum": ["top_left", "top_right", "bottom_left", "bottom_right", "center", "fullscreen"] },
          "scale": { "type": "number", "minimum": 0.01, "maximum": 1, "description": "Overlay width as a fraction of frame width (ignored for fullscreen)." },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "margin": { "type": "number", "minimum": 0, "maximum": 500 },
          "blend": { "enum": ["alpha", "screen", "add"], "description": "'screen' = soft light composite for black-bg loops; 'add' = hotter version of screen (clips sooner — pair with lower opacity)." },
          "start": { "type": "number", "minimum": 0 },
          "end": { "type": "number", "exclusiveMinimum": 0, "description": "Must be > start." }
        }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },

  "$defs": {
    "effect": {
      "enum": [
        "still", "slow_zoom_in", "slow_zoom_out",
        "pan_left", "pan_right", "pan_up", "pan_down",
        "kenburns_tl", "kenburns_tr", "kenburns_bl", "kenburns_br",
        "portrait_blur_background", "polaroid", "circle_focus",
        "memory_wall", "dark_feather",
        "film_roll_up", "film_roll_left", "film_roll_right",
        "video_background", "collage_grid", "double_exposure",
        "layer_scene"
      ]
    },
    "transitionType": {
      "enum": [
        "none", "crossfade", "fade_fast", "fade_slow", "fade_to_black", "fade_to_white",
        "fade_grays", "dissolve", "pixelize", "radial", "distance", "blur", "zoom_in",
        "wipe_left", "wipe_right", "wipe_up", "wipe_down",
        "wipe_tl", "wipe_tr", "wipe_bl", "wipe_br",
        "slide_left", "slide_right", "slide_up", "slide_down",
        "smooth_left", "smooth_right", "smooth_up", "smooth_down",
        "circle_open", "circle_close", "circle_crop", "rect_crop",
        "horz_open", "horz_close", "vert_open", "vert_close",
        "diag_tl", "diag_tr", "diag_bl", "diag_br",
        "slice_left", "slice_right", "slice_up", "slice_down",
        "wind_left", "wind_right", "wind_up", "wind_down",
        "cover_left", "cover_right", "cover_up", "cover_down",
        "reveal_left", "reveal_right", "reveal_up", "reveal_down",
        "squeeze_h", "squeeze_v"
      ]
    },
    "curvesPreset": {
      "enum": ["color_negative", "cross_process", "darker", "increase_contrast", "lighter",
        "linear_contrast", "medium_contrast", "negative", "strong_contrast", "vintage"]
    },
    "colorGrade": {
      "type": "object",
      "description": "Global (timeline.color) and/or per-slide (slide.color); per-slide overrides field-by-field.",
      "properties": {
        "brightness": { "type": "number", "minimum": -1, "maximum": 1 },
        "contrast": { "type": "number", "minimum": 0, "maximum": 3 },
        "saturation": { "type": "number", "minimum": 0, "maximum": 3 },
        "gamma": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "curves": { "$ref": "#/$defs/curvesPreset" },
        "lut": { "type": "string", "minLength": 1, "description": "Path to a .cube LUT." },
        "vignette": { "anyOf": [{ "type": "boolean" }, { "type": "number", "minimum": 0, "maximum": 3.1416 }] },
        "sharpen": { "type": "number", "minimum": 0, "maximum": 2 },
        "blur": { "type": "number", "minimum": 0, "maximum": 50, "description": "Gaussian sigma (soft-focus)." },
        "temperature": { "type": "number", "minimum": 1000, "maximum": 40000, "description": "Kelvin; <6500 warmer." },
        "glow": { "type": "number", "minimum": 0, "maximum": 1, "description": "Dreamy bloom." },
        "grain": { "type": "number", "minimum": 0, "maximum": 30, "description": "Animated film grain." },
        "letterbox": { "anyOf": [{ "type": "boolean" }, { "type": "number", "minimum": 1, "maximum": 4 }] }
      }
    },
    "caption": {
      "type": "object",
      "required": ["text", "role", "position", "start", "duration", "color", "shadow", "animation"],
      "properties": {
        "text": { "type": "string" },
        "role": { "enum": ["title", "subtitle", "caption"], "description": "Presets the font size." },
        "position": { "enum": ["bottom_center", "center", "top_center", "none"] },
        "start": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "minimum": 0 },
        "font": { "type": "string", "minLength": 1 },
        "size": { "type": "integer", "exclusiveMinimum": 0 },
        "color": { "type": "string", "minLength": 1 },
        "outline": {
          "type": "object",
          "required": ["color", "width"],
          "properties": {
            "color": { "type": "string", "minLength": 1 },
            "width": { "type": "number", "minimum": 0, "maximum": 20 }
          }
        },
        "shadow": { "type": "boolean" },
        "animation": { "enum": ["fade", "slide_up", "none"] }
      },
      "$comment": "cap.start + cap.duration MUST be <= slide.duration."
    },
    "baseLayer": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "x": { "type": "number", "description": "Top-left X on the canvas (may be negative to bleed off-frame)." },
        "y": { "type": "number", "description": "Top-left Y on the canvas (may be negative)." },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 },
        "rotation": { "type": "number", "minimum": -360, "maximum": 360, "description": "Degrees; images only render rotation." },
        "start": { "type": "number", "minimum": 0, "default": 0, "description": "Seconds from slide start when this layer appears." },
        "duration": { "type": "number", "minimum": 0, "description": "Seconds visible; defaults to the rest of the slide." },
        "animation": {
          "enum": ["none", "fade", "slide_up", "slide_down", "slide_left", "slide_right"],
          "default": "none",
          "description": "Entrance. fade = alpha in/out (capped 0.5s each end). slide_* = drift in from that edge over the layer's fade window."
        }
      },
      "$comment": "layer.start + (layer.duration OR slide.duration - start) MUST be <= slide.duration."
    },
    "layer": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "path", "x", "y", "width", "height"],
          "properties": {
            "type": { "const": "image" },
            "path": { "type": "string", "minLength": 1 },
            "fit": { "enum": ["cover", "contain", "stretch"], "default": "cover", "description": "cover = fill+crop (frames); contain = fit inside, no crop; stretch = distort." },
            "motion": { "enum": ["none", "zoom_in", "zoom_out", "pan_left", "pan_right", "pan_up", "pan_down"], "description": "Continuous Ken-Burns over the whole slide (implies cover)." },
            "frame": {
              "type": "object",
              "description": "Card treatment: rounded corners, white matte border, soft drop shadow.",
              "properties": {
                "radius": { "type": "number", "minimum": 0, "maximum": 400, "description": "Rounded-corner radius in px." },
                "border": { "type": "number", "minimum": 0, "maximum": 200, "description": "Matte border thickness in px (keeps outer size = width×height)." },
                "borderColor": { "type": "string", "minLength": 1, "description": "Default white." },
                "shadow": { "type": "boolean", "description": "Soft blurred drop shadow behind the card." }
              }
            }
          },
          "$ref": "#/$defs/baseLayer",
          "unevaluatedProperties": false
        },
        {
          "type": "object",
          "required": ["type", "color", "x", "y", "width", "height"],
          "properties": {
            "type": { "const": "rect" },
            "color": { "type": "string", "minLength": 1, "description": "Named or #rrggbb. Square corners (drawbox)." }
          },
          "$ref": "#/$defs/baseLayer",
          "unevaluatedProperties": false
        },
        {
          "type": "object",
          "required": ["type", "text", "size", "color", "x", "y", "width", "height"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string", "description": "drawtext does NOT auto-wrap — insert explicit \\n for line breaks." },
            "font": { "type": "string", "minLength": 1, "description": "Path to a .ttf/.otf under fonts/." },
            "size": { "type": "integer", "exclusiveMinimum": 0, "description": "Pixel em size." },
            "color": { "type": "string", "minLength": 1 },
            "align": { "enum": ["left", "center", "right"], "default": "left", "description": "Alignment of text inside the x..x+width box." },
            "lineSpacing": { "type": "number", "exclusiveMinimum": 0 },
            "letterSpacing": { "type": "number", "description": "NOTE: currently only toggles harfbuzz shaping; it does NOT apply tracking." },
            "wrap": { "type": "boolean", "description": "Auto-wrap the text to the layer width at compile time (greedy word-wrap; explicit \\n are kept). Removes the need to hand-insert line breaks." }
          },
          "$ref": "#/$defs/baseLayer",
          "unevaluatedProperties": false
        }
      ]
    },
    "slide": {
      "type": "object",
      "required": ["id", "duration", "effect", "transition", "captions"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "description": "Unique across the timeline." },
        "image": { "type": "string", "minLength": 1, "description": "One photo for single-image effects." },
        "images": { "type": "array", "items": { "type": "string", "minLength": 1 }, "description": "Multiple photos for film_roll_*/collage_grid/double_exposure (>=2) or memory_wall (1-5)." },
        "background": { "type": "string", "minLength": 1, "description": "Looping video file for video_background." },
        "layers": { "type": "array", "items": { "$ref": "#/$defs/layer" }, "description": "Required for layer_scene; drawn back-to-front." },
        "duration": { "type": "number", "minimum": 2, "maximum": 30, "description": "Seconds. HARD limits 2..30." },
        "effect": { "$ref": "#/$defs/effect" },
        "easing": {
          "enum": ["gentle", "snap", "bounce"],
          "description": "Motion easing for zoom/pan/kenburns effects ONLY (the engine rejects it elsewhere). Omitted = house smoothstep. gentle = extra-soft start/stop (calm, portrait, emotional beats) · snap = fast, decisive ease-out (party/dance/peak beats) · bounce = small overshoot that settles back (easy to overuse — max 1-2 slides per video)."
        },
        "transition": {
          "type": "object",
          "required": ["type", "duration"],
          "properties": {
            "type": { "$ref": "#/$defs/transitionType" },
            "duration": { "type": "number", "minimum": 0, "maximum": 2, "description": "Into the NEXT slide. HARD max 2s; MUST be < this slide's duration." }
          }
        },
        "captions": { "type": "array", "items": { "$ref": "#/$defs/caption" }, "description": "Baked-in drawtext lines. For layer_scene prefer text layers instead." },
        "color": { "$ref": "#/$defs/colorGrade" }
      },
      "allOf": [
        {
          "if": { "properties": { "effect": { "const": "layer_scene" } } },
          "then": { "required": ["layers"], "properties": { "layers": { "minItems": 1 } } }
        },
        {
          "if": { "properties": { "effect": { "enum": ["film_roll_up", "film_roll_left", "film_roll_right", "collage_grid", "double_exposure"] } } },
          "then": { "required": ["images"], "properties": { "images": { "minItems": 2 } } }
        },
        {
          "if": { "properties": { "effect": { "const": "memory_wall" } } },
          "then": { "required": ["images"], "properties": { "images": { "minItems": 1, "maxItems": 5 } } }
        },
        {
          "if": { "properties": { "effect": { "const": "video_background" } } },
          "then": { "required": ["background"] }
        },
        {
          "if": { "properties": { "effect": { "enum": ["still", "slow_zoom_in", "slow_zoom_out", "pan_left", "pan_right", "pan_up", "pan_down", "kenburns_tl", "kenburns_tr", "kenburns_bl", "kenburns_br", "portrait_blur_background", "polaroid", "circle_focus", "dark_feather"] } } },
          "then": { "required": ["image"] }
        }
      ]
    }
  }
}
