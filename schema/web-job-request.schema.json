{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "web-job-request.schema.json",
  "title": "Web slideshow job request",
  "type": "object",
  "additionalProperties": false,
  "required": ["webLanguage", "sequenceMode", "tier", "prompt", "photos"],
  "properties": {
    "language": { "enum": ["vi", "en"] },
    "webLanguage": { "enum": ["vi", "en"] },
    "sequenceMode": { "enum": ["editorial", "chronological"] },
    "tier": { "enum": ["template", "lite", "premium"] },
    "prompt": { "type": "string", "maxLength": 10000 },
    "musicMode": { "enum": ["auto", "highlight", "full_song"] },
    "recipe": { "type": "string", "minLength": 1 },
    "photos": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "uploadIndex"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "uploadIndex": { "type": "integer", "minimum": 0 },
          "capturedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
