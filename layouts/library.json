    "fontRegistry": {
      "note": "VIETNAMESE RULE: any text with Vietnamese diacritics MUST use body (BeVietnamPro) or heading (PlayfairDisplay) — both carry full VN marks. Script/decorative fonts are Latin-only; use them for English words like 'the', 'save', or the couple's romanized names, never for Vietnamese sentences.",
      "vietnamese_safe": [
        "fonts/BeVietnamPro-Regular.ttf",
        "fonts/PlayfairDisplay.ttf"
      ],
      "latin_decorative": [
        "fonts/GreatVibes-Regular.ttf",
        "fonts/DancingScript.ttf",
        "fonts/Italianno-Regular.ttf",
        "fonts/WindSong-Medium.ttf",
        "fonts/Pacifico-Regular.ttf",
        "fonts/Lobster-Regular.ttf",
        "fonts/Charm-Regular.ttf",
        "fonts/MeaCulpa-Regular.ttf"
      ]
    },
    "typeScale": {
      "note": "Pixel em sizes tuned for PlayfairDisplay/BeVietnamPro on 1920x1080. Numerals are display-only.",
      "hero_numeral": [
        200,
        260
      ],
      "display": [
        96,
        120
      ],
      "heading": [
        78,
        100
      ],
      "subheading": [
        48,
        64
      ],
      "body": [
        30,
        40
      ],
      "eyebrow": [
        64,
        88
      ]
    },
    "motionPresets": {
      "note": "Entrance animation: none | fade | slide_up | slide_down | slide_left | slide_right (directional = drift in from that edge, already smoothstep-eased). Continuous Ken-Burns is a separate image-layer field `motion`: zoom_in | zoom_out | pan_left | pan_right | pan_up | pan_down.",
      "gentle": {
        "text": "fade",
        "photo": "fade"
      },
      "rise": {
        "text": "fade",
        "photo": "slide_up"
      },
      "drift_in": {
        "text": "fade",
        "photoFromEdge": true
      },
      "kenburns_bg": {
        "photoMotion": "zoom_in",
        "use": "full-bleed backgrounds and emotional hero photos"
      },
      "staggerSeconds": {
        "heading": 0.2,
        "body": 0.6,
        "photoBase": 0.15,
        "photoStep": 0.1
      }
    },
    "framePreset": {
      "note": "Give photo layers a `frame` for the Canva card look (rounded + white matte + soft shadow).",
      "card": {
        "radius": 28,
        "border": 12,
        "borderColor": "#FFFFFF",
        "shadow": true
      },
      "softCard": {
        "radius": 20,
        "border": 8,
        "borderColor": "#FFFFFF",
        "shadow": true
      }
    },
    "textWrap": {
      "note": "Set `wrap: true` on body text layers so the engine wraps to the slot width automatically (no manual \\n)."
    },
    "pacing": {
      "note": "Scene duration by emotional weight; keep within engine hard limits 2..30s.",
      "quick_montage_beat": [
        2.5,
        3.5
      ],
      "standard_scene": [
        4.5,
        6.0
      ],
      "hero_or_emotional": [
        6.0,
        8.0
      ],
      "closing_hold": [
        7.0,
        10.0
      ],
      "transitionByMood": {
        "calm": [
          0.7,
          1.2
        ],
        "upbeat": [
          0.35,
          0.6
        ],
        "hard_cut": [
          0.0,
          0.0
        ]
      }
    }
