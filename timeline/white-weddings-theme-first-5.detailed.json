{
  "documentation": {
    "title": "White Weddings Theme — detailed timeline of the first 5 scenes",
    "purpose": "Ground-truth reconstruction of scenes 1-5 of the reference Save-the-Date video, derived from powerpoints.pptx (exact geometry), the White Weddings SVG deck, and frame-accurate measurement of the reference MP4. This file is authoritative documentation AND a runnable engine timeline (effect=layer_scene).",
    "sourceTheme": "templates/Weddings/White Weddings Theme",
    "sourceFiles": {
      "pptx": "powerpoints.pptx (316 slides, slide N = svg N)",
      "svg": "White Weddings svg/1.svg .. 316.svg (output 1920x1080, internal viewBox 1440x810)",
      "mp4": "Bản sao của White Elegant Wedding Save the Date Video.mp4 (1920x1080, 30fps, h264, total 3088.9s / 316 scenes)"
    },
    "canvas": { "width": 1920, "height": 1080, "background": "#FBF6ED (warm cream)" },
    "measuredSceneTiming": {
      "note": "Scene start = start of visible content; boundaries are ~0.6-0.8s crossfades so ±0.4s. The 9.775s figure in the older analysis is only total/316 (an average across the WHOLE 51-min deck); the intro scenes actually run ~4-5.6s each.",
      "scene1_save_the_date": { "start": 0.0, "end": 5.2, "span": 5.2 },
      "scene2_invitation":    { "start": 5.2, "end": 10.8, "span": 5.6 },
      "scene3_special_day":   { "start": 10.8, "end": 15.0, "span": 4.2 },
      "scene4_story":         { "start": 15.0, "end": 19.3, "span": 4.3 },
      "scene5_big_day":       { "start": 19.3, "end": 23.6, "span": 4.3 }
    },
    "fontMapping": {
      "note": "Reference Canva fonts are not shipped locally; nearest local substitutes are used.",
      "Perandory (SAVE/DATE, numerals)": "fonts/PlayfairDisplay.ttf",
      "Pinyon Script ('the')": "fonts/GreatVibes-Regular.ttf",
      "Noto Serif Display (headings)": "fonts/PlayfairDisplay.ttf",
      "Vietnamese body copy": "fonts/BeVietnamPro-Regular.ttf"
    },
    "palette": { "cream_bg": "#FBF6ED", "ink_dark": "#2D2D33", "warm_brown_text": "#634C31", "numeral_white": "#FFFDFC" },
    "animationModel": {
      "intraScene": "Elements fade in staggered over the first ~1-1.5s (heading first, body copy ~0.4-0.6s later). Background photos hold with a slow Ken-Burns zoom.",
      "scene1_special": "After the hold, the cream SAVE-the-DATE card dissolves away (~t=4) to reveal the full-bleed couple photo with only the numerals, then crossfades to scene 2.",
      "betweenScenes": "Soft crossfade (~0.7s)."
    },
    "engineFidelityNotes": [
      "layer_scene reproduces: full-bleed background photo, N positioned/cropped photo cards, multi-font positioned text (incl. Vietnamese), cream panels (drawbox), per-layer fade in/out, crossfade between scenes, music.",
      "Approximated / not 1:1: rounded-corner photo/card frames (drawbox is square-cornered), exact Canva fonts, the scene-1 card-dissolve reveal (engine fades the whole card, no wipe/slide-out), per-layer Ken-Burns inside a layer_scene (background zoom is not animated per-layer), and the small decorative ampersand/leaf SVGs (image112.svg not present in extracted assets).",
      "drawtext does not auto-wrap: long body copy must carry explicit newlines (done below)."
    ]
  },

