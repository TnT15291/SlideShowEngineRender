# This file belongs at the repository root. Both Vite and the API read root .env.
# Keep /api when Vite proxies to the local API server.
VITE_API_BASE_URL=/api

# StoReel API server. Kept on loopback by default — the Vite dev/preview
# server below (apps/web) already binds 0.0.0.0 and proxies /api to this
# local address, so a phone only ever needs to reach Vite's port, not the
# API port directly. Only widen this if something outside Vite's proxy
# needs to call the API from another device.
STOREEL_API_HOST=127.0.0.1
STOREEL_API_PORT=8787
# Comma-separated allow-list of browser origins allowed to call the API.
# Add your phone-reachable LAN origin when testing on a device, e.g.
# STOREEL_WEB_ORIGINS=http://127.0.0.1:5173,http://192.168.1.23:5173
STOREEL_WEB_ORIGINS=http://127.0.0.1:5173

# Optional paid semantic photo analysis. Leave the key empty to keep vision disabled.
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-5.5

# Optional for non-OpenAI-compatible providers so the web UI can estimate USD.
# VISION_INPUT_USD_PER_MILLION=5
# VISION_OUTPUT_USD_PER_MILLION=30

# Stripe billing. Leave STRIPE_SECRET_KEY empty to keep /api/billing/*
# disabled (returns 409 STRIPE_NOT_CONFIGURED) — plans stay CLI-only via
# scripts/setUserPlan.mjs until this is set. Get test-mode keys from
# https://dashboard.stripe.com/test/apikeys. For local webhook delivery run
# `stripe listen --forward-to localhost:8787/api/billing/webhook` (Stripe
# CLI) and copy the whsec_... it prints into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
# Prices below are placeholders — nothing real was decided yet. Change them
# any time; no code deploy needed.
STRIPE_SUBSCRIPTION_PRICE_CENTS=2900
STRIPE_SUBSCRIPTION_QUOTA=10
STRIPE_PER_VIDEO_PRICE_CENTS=1500

# Admin incident center. Only these comma-separated usernames can open /api/admin/*.
STOREEL_ADMIN_USERNAMES=storeel
# Optional email alerts through Resend. Incidents are still stored when unset.
RESEND_API_KEY=
STOREEL_ALERT_EMAIL=
STOREEL_ALERT_FROM=StoReel Alerts <onboarding@resend.dev>
